{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/index.go",
      "use": "@vercel/go"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health/index.go"
    },
    {
      "src": "/api/scan",
      "dest": "/api/scan/index.go"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
